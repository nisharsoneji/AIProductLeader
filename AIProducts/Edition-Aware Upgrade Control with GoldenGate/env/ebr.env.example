# Copy to env/ebr.env and fill in the GoldenGate Admin Service details.

# For private deployments over a bastion tunnel, this is commonly:
# export OGG_BASE_URL="https://localhost:8080"
export OGG_BASE_URL="https://localhost:8080"
export OGG_USERNAME="oggadmin"
export OGG_PASSWORD=""
export OGG_PASSWORD_FILE=""
export OGG_VERIFY_TLS="false"

export OGG_DOMAIN="OracleGoldenGate"
export OGG_SOURCE_ALIAS="srcAtp"
export OGG_TARGET_ALIAS="srcAtp"
export OGG_CHECKPOINT_TABLE="SRCMIRROR_OCIGGLL.GGCHKPT"

export SRC_SCHEMA="SRC_OCIGGLL"
export TGT_SCHEMA="SRCMIRROR_OCIGGLL"
export EBR_TABLE="EBR_ORDER_DEMO"

export APP_EXTRACT_NAME="EBRAPPX"
export APP_REPLICAT_NAME="EBRAPPR"
export APP_TRAIL_NAME="ea"

export INSTALL_EXTRACT_NAME="EBRINSX"
export INSTALL_REPLICAT_NAME="EBRINSR"
export INSTALL_TRAIL_NAME="ei"

export INSTALL_USER="EBR_INSTALL_USER"
